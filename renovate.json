{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":semanticCommits",
    "config:best-practices",
    "group:monorepos",
    "group:recommended"
  ],
  "ignorePresets": ["workarounds:typesNodeVersioning"],
  "postUpdateOptions": ["pnpmDedupe"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    { "matchDepNames": ["node"], "ignoreUnstable": false },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "pinDigest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchDepNames": ["binaryen", "rust-nightly"],
      "automerge": true
    },
    {
      "description": "Limit Rust nightly updates to the 1st and 15th of each month",
      "matchDepNames": "rust",
      "allowedVersions": "/01|15$/"
    }
  ]
}
